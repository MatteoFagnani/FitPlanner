generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  coach
  athlete
}

enum ProgramStatus {
  active
  archived
}

model User {
  id               String       @id @default(cuid())
  name             String
  email            String       @unique
  password         String
  role             UserRole
  createdAt        DateTime     @default(now())
  oneRMs           OneRM[]
  programsCoached  Program[]
  sessions         Session[]
}

model OneRM {
  id        String   @id @default(cuid())
  exercise  String
  value     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exercise])
}

model Program {
  id         String   @id
  title      String
  status     ProgramStatus   @default(active)
  coachId    String
  athleteIds Json
  weeks      Json
  createdAt  DateTime
  updatedAt  DateTime @updatedAt
  coach      User     @relation(fields: [coachId], references: [id], onDelete: Cascade)
}

model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
